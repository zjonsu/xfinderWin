<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 다크 테마 — mac 다크 모드 근사 (스펙 02 §12) -->
    <Color x:Key="WindowBackgroundColor">#FF2B2B2D</Color>
    <Color x:Key="SidebarBackgroundColor">#FF262626</Color>
    <Color x:Key="ContentBackgroundColor">#FF2B2B2D</Color>
    <Color x:Key="TextBackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="TextPrimaryColor">#FFEDEDEF</Color>
    <Color x:Key="TextSecondaryColor">#99FFFFFF</Color>
    <Color x:Key="AccentColor">#FF0A84FF</Color>
    <Color x:Key="SelectionColor">#FF0A84FF</Color>
    <Color x:Key="SelectionInactiveColor">#40FFFFFF</Color>
    <Color x:Key="DividerColor">#FF3D3D40</Color>
    <Color x:Key="HoverColor">#1AFFFFFF</Color>
    <Color x:Key="ControlFillColor">#0DFFFFFF</Color>
    <Color x:Key="ControlFillHoverColor">#1AFFFFFF</Color>
    <Color x:Key="ControlStrokeColor">#0FFFFFFF</Color>
    <Color x:Key="MenuBackgroundColor">#FF2D2D30</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}"/>
    <SolidColorBrush x:Key="TextBackgroundBrush" Color="{StaticResource TextBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="SelectionInactiveBrush" Color="{StaticResource SelectionInactiveColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ControlFillBrush" Color="{StaticResource ControlFillColor}"/>
    <SolidColorBrush x:Key="ControlFillHoverBrush" Color="{StaticResource ControlFillHoverColor}"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="{StaticResource ControlStrokeColor}"/>
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="{StaticResource MenuBackgroundColor}"/>

</ResourceDictionary>
