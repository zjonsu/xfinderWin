<!-- mac 대응: Sources/XFinder/Views/UninstallSheet.swift — Windows 재설계: 설치 프로그램 목록 + 잔재 체크 목록 (스펙 04 §11) -->
<Window x:Class="XFinder.Views.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로그램 제거" Width="920" Height="640" MinWidth="780" MinHeight="500"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- 선택 행 배경 (라이트/다크 모두 읽히도록 반투명 악센트) -->
        <SolidColorBrush x:Key="RowSelectionBrush" Color="{DynamicResource AccentColor}" Opacity="0.28"/>

        <!-- 설치 앱 목록 행 -->
        <Style x:Key="AppRowContainer" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" CornerRadius="6" Padding="8,6" Margin="0,1" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RowSelectionBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 잔재 행 호버 -->
        <Style x:Key="ResidueRowBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 체크박스 (테마 인지) -->
        <Style x:Key="CheckStyle" TargetType="CheckBox">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box" Width="16" Height="16" CornerRadius="4"
                                Background="{DynamicResource ControlFillBrush}"
                                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1">
                            <TextBlock x:Name="Mark" Text="&#xE73E;" FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="10" FontWeight="Bold" Foreground="White" Visibility="Collapsed"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 텍스트 링크 버튼 (모두 선택/해제) -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 위험 동작 버튼 (빨강) -->
        <Style x:Key="DestructiveButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="9" Background="#E83B30"
                                Padding="{TemplateBinding Padding}" Opacity="0.92">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Opacity" Value="1.0"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ── 본문 ─────────────────────────────────────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,12,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌: 설치된 프로그램 목록 -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <Button x:Name="BtnRefresh" DockPanel.Dock="Right" Style="{StaticResource NavButton}"
                                Margin="6,0,0,0" Content="&#xE72C;"
                                ToolTip="설치된 프로그램 목록 새로 고침" Click="OnRefresh"/>
                        <Grid>
                            <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" FontSize="12"
                                     TextChanged="OnSearchChanged"/>
                            <TextBlock x:Name="SearchHint" Text="이름·게시자 검색" FontSize="12" Margin="10,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </DockPanel>

                    <Border Grid.Row="2" CornerRadius="8"
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                        <Grid>
                            <ListBox x:Name="AppList" Background="Transparent" BorderThickness="0" Padding="4"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     ItemContainerStyle="{StaticResource AppRowContainer}"
                                     SelectionChanged="OnAppSelected">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{Binding Icon}" Width="24" Height="24"
                                                   VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="8,0,6,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Publisher}" FontSize="10.5"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="10.5"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="AppsLoading" Text="설치된 프로그램을 읽는 중…" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AppsEmpty" Text="일치하는 프로그램이 없습니다." FontSize="12"
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="4" x:Name="CountText" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>

                <!-- 우: 선택 앱 정보 + 잔재 후보 목록 -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock x:Name="AppNameText" Text="프로그램을 선택하세요" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="AppMetaText" FontSize="11.5" Margin="0,3,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ScanStatus" FontSize="11.5" FontWeight="SemiBold" Margin="0,3,0,0"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>

                    <Border Grid.Row="2" CornerRadius="8"
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                <ItemsControl x:Name="ResidueList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ResidueRowBorder}" CornerRadius="6"
                                                    Padding="10,7" Margin="0,1" Cursor="Hand"
                                                    MouseLeftButtonUp="OnResidueRowClick">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Style="{StaticResource CheckStyle}"
                                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Margin="10,0,8,0"
                                                                VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                                       FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Border CornerRadius="4" Padding="5,1" Margin="6,0,0,0"
                                                                    Background="{DynamicResource ControlFillBrush}"
                                                                    BorderBrush="{DynamicResource ControlStrokeBrush}"
                                                                    BorderThickness="0.5" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Kind}" FontSize="9.5"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding DisplayPath}" FontSize="10.5"
                                                                   Margin="0,1,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <Button Grid.Column="3" Style="{StaticResource IconButton}"
                                                            Width="22" Height="20" FontSize="11"
                                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                                            Content="&#xE721;" ToolTip="탐색기에서 보기"
                                                            Click="OnRevealResidue"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="ResiduePlaceholder" FontSize="12" TextAlignment="Center"
                                       Text="왼쪽 목록에서 프로그램을 선택하면&#10;설정·캐시·바로가기 등 잔재 후보를 찾습니다."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 푸터 -->
            <Border Grid.Row="1" Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="14,10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="BtnClose" Style="{StaticResource DialogButton}" Padding="18,8"
                                Content="닫기" Click="OnCloseClick"/>
                        <Button x:Name="BtnTrash" Style="{StaticResource DestructiveButton}" Margin="10,0,0,0"
                                Content="잔재만 휴지통으로"
                                ToolTip="체크한 잔재 항목만 휴지통으로 이동합니다 (제거 프로그램은 실행하지 않음)"
                                Click="OnTrashResidue"/>
                        <Button x:Name="BtnUninstall" Style="{StaticResource DestructiveButton}" Margin="10,0,0,0"
                                Content="제거 실행"
                                ToolTip="선택한 프로그램의 제거 프로그램(UninstallString)을 실행합니다"
                                Click="OnRunUninstall"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnSelectAll" Style="{StaticResource LinkButton}" Content="모두 선택"
                                Click="OnSelectAll"/>
                        <Button x:Name="BtnClearAll" Style="{StaticResource LinkButton}" Content="모두 해제"
                                Margin="12,0,0,0" Click="OnClearAll"/>
                        <TextBlock x:Name="SummaryText" FontSize="11.5" Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── 알림 오버레이 ────────────────────────────────────────── -->
        <Grid x:Name="AlertOverlay" Visibility="Collapsed" Background="#48000000"
              MouseLeftButtonDown="OnAlertScrim">
            <Border Width="360" Padding="20" CornerRadius="16" VerticalAlignment="Center"
                    Background="{DynamicResource MenuBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlStrokeBrush}" BorderThickness="1"
                    MouseLeftButtonDown="OnPanelClickEat">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="AlertTitle" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="AlertMessage" FontSize="12" Margin="0,14,0,0" TextWrapping="Wrap"
                               TextAlignment="Center" MaxHeight="320"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Margin="0,16,0,0" Style="{StaticResource DialogButton}" Content="확인"
                            Click="OnAlertOk"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── 확인 다이얼로그 오버레이 ─────────────────────────────── -->
        <Grid x:Name="ConfirmOverlay" Visibility="Collapsed" Background="#48000000"
              MouseLeftButtonDown="OnConfirmScrim">
            <Border Width="340" Padding="20" CornerRadius="16" VerticalAlignment="Center"
                    Background="{DynamicResource MenuBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlStrokeBrush}" BorderThickness="1"
                    MouseLeftButtonDown="OnPanelClickEat">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="ConfirmMessage" FontSize="12" Margin="0,14,0,0" TextWrapping="Wrap"
                               TextAlignment="Center" MaxHeight="320"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ConfirmActionBtn" Grid.Column="0" Style="{StaticResource DialogButton}"
                                Click="OnConfirmAction"/>
                        <Button x:Name="ConfirmCancelBtn" Grid.Column="2" Style="{StaticResource DialogButton}"
                                Content="취소" Click="OnConfirmCancel"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
