<UserControl x:Class="XFinder.Views.Monitor.CpuDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- mac 소스 대응: Sources/XFinder/Views/CPUDetailView.swift — CPU 팝업 (너비 360, 높이 자동) -->
    <StackPanel Width="328" Margin="16">

        <!-- 칩 이름 + 코어 수 -->
        <TextBlock x:Name="ChipName" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="CoreText" FontSize="11" Margin="0,2,0,0"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <!-- 사용률 그래프 (CpuHistory 60개 = 2분 추이) -->
        <Border Height="120" CornerRadius="8" Margin="0,16,0,0" ClipToBounds="True">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.05"/>
            </Border.Background>
            <Canvas x:Name="ChartCanvas" ClipToBounds="True"/>
        </Border>

        <!-- 사용률 수치 3개 (사용 가능/사용자/시스템) -->
        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Rectangle Width="4" Height="34" RadiusX="2" RadiusY="2"
                           Fill="{DynamicResource TextSecondaryBrush}"/>
                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="IdleValue" Text="0.0%" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="사용 가능" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Rectangle Width="4" Height="34" RadiusX="2" RadiusY="2" Fill="#0A84FF"/>
                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="UserValue" Text="0.0%" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="사용자" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Rectangle Width="4" Height="34" RadiusX="2" RadiusY="2" Fill="#FF453A"/>
                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="SysValue" Text="0.0%" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="시스템" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,16,0,0"/>

        <!-- 카드 2개: 가동시간 / 온도 -->
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
                </Border.Background>
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="가동시간" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="UptimeValue" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </DockPanel>
                    <TextBlock x:Name="UptimeDesc" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
                </Border.Background>
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" x:Name="TempTitle" Text="온도" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="TempValue" Text="—" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </DockPanel>
                    <TextBlock x:Name="TempDesc" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,16,0,0"/>

        <!-- 상위 프로세스 (2초 타이머 갱신 — 팝업 열릴 때만) -->
        <TextBlock Text="부하가 가장 큰 프로세스" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <DockPanel LastChildFill="False" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left" Text="프로세스 이름" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock DockPanel.Dock="Right" Text="사용량" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </DockPanel>
        <StackPanel x:Name="ProcList" Margin="0,4,0,0"/>
    </StackPanel>
</UserControl>
