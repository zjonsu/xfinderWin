<UserControl x:Class="XFinder.Views.Monitor.MemoryDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- mac 소스 대응: Sources/XFinder/Views/MemoryDetailView.swift — 메모리 팝업 (360×540 고정, 내용 스크롤) -->
    <ScrollViewer Width="360" Height="540" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">

            <TextBlock Text="메모리" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <!-- 도넛 + 범례 -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="130" Height="130">
                    <Canvas x:Name="DonutCanvas" Width="130" Height="130"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="CenterUsed" Text="0.00GB" FontSize="19" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="CenterTotal" Text="/ 0GB" FontSize="10"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="#0A84FF" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="활성화" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="LegendActive" Text="0.00GB" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Ellipse Width="9" Height="9" Fill="#BF5AF2" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="와이어드" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="LegendWired" Text="0.00GB" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Ellipse Width="9" Height="9" Fill="#5E5CE6" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="압축됨" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="LegendCompressed" Text="0.00GB" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,16,0,0"/>

            <!-- 카드 2개: 압력 / 스왑 파일 -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="10" Padding="10">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
                    </Border.Background>
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="압력" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock DockPanel.Dock="Right" x:Name="PressureValue" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </DockPanel>
                        <TextBlock x:Name="PressureDesc" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="10" Padding="10">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
                    </Border.Background>
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="스왑 파일" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock DockPanel.Dock="Right" x:Name="SwapValue" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </DockPanel>
                        <TextBlock Text="메모리 성능을 돕는 디스크 영역입니다." FontSize="11" TextWrapping="Wrap"
                                   Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,16,0,0"/>

            <!-- 상위 프로세스 (RSS 기준 6개 — 3초 타이머, 팝업 열릴 때만) -->
            <TextBlock Text="부하가 가장 큰 프로세스" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,0"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <DockPanel LastChildFill="False" Margin="0,8,0,0">
                <TextBlock DockPanel.Dock="Left" Text="프로세스 이름" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock DockPanel.Dock="Right" Text="사용량" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </DockPanel>
            <StackPanel x:Name="ProcList" Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
