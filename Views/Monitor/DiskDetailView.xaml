<UserControl x:Class="XFinder.Views.Monitor.DiskDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- mac 소스 대응: Sources/XFinder/Views/DiskDetailView.swift — 디스크 팝업 (너비 380, 높이 자동) -->
    <StackPanel Width="348" Margin="16">

        <!-- 헤더: 볼륨 이름 + 다시 계산/캐시 시각 -->
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button x:Name="RecalcBtn" Click="OnRecalc" Cursor="Hand" Focusable="False"
                        HorizontalAlignment="Right" ToolTip="디스크 분류와 종류별 파일 계산을 다시 수행">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RecalcIcon" FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="11" Foreground="#0A84FF" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RecalcLabel" Text="다시 계산" FontSize="12" FontWeight="Medium"
                                   Foreground="#0A84FF" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="CacheTime" FontSize="9" Margin="0,2,0,0" HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <TextBlock x:Name="VolName" Text="디스크" FontSize="18" FontWeight="Bold"
                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </DockPanel>

        <!-- 도넛 + 범례 -->
        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="140" Height="140">
                <Canvas x:Name="DonutCanvas" Width="140" Height="140"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="CenterFree" Text="--" FontSize="19" FontWeight="Bold"
                               Foreground="#FF9F0A" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CenterTotal" Text="/ --" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="사용 가능" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <StackPanel x:Name="LegendPanel" Grid.Column="2" VerticalAlignment="Center"/>
        </Grid>

        <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,14,0,0"/>

        <!-- 카드 2개: 건강 상태(S.M.A.R.T.) / 온도 -->
        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
                </Border.Background>
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="건강 상태" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="HealthValue" Text="—" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </DockPanel>
                    <TextBlock x:Name="HealthDesc" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
                </Border.Background>
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="온도" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="TempValue" Text="—" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </DockPanel>
                    <TextBlock x:Name="TempDesc" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 휴지통: 크기 + 비우기 -->
        <Border CornerRadius="10" Padding="10" Margin="0,10,0,0">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
            </Border.Background>
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="휴지통" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button DockPanel.Dock="Right" x:Name="EmptyTrashBtn" Click="OnEmptyTrash"
                        Cursor="Hand" Focusable="False" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="휴지통 비우기" FontSize="11" FontWeight="Medium" Foreground="#0A84FF"/>
                </Button>
                <TextBlock DockPanel.Dock="Right" x:Name="TrashValue" Text="—" FontSize="14" FontWeight="Bold"
                           Margin="0,0,10,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </DockPanel>
        </Border>

        <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,14,0,0"/>

        <!-- 파일 계산 -->
        <DockPanel LastChildFill="True" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left" Text="파일 계산" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="HomePath" FontSize="10" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"
                       TextAlignment="Right" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </DockPanel>

        <Border CornerRadius="12" Padding="12,4" Margin="0,8,0,0">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource TextPrimaryColor}" Opacity="0.06"/>
            </Border.Background>
            <StackPanel x:Name="TypeList"/>
        </Border>
    </StackPanel>
</UserControl>
