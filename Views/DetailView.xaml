<UserControl x:Class="XFinder.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XFinder.Views"
             Background="{DynamicResource TextBackgroundBrush}"
             Focusable="False">
    <!-- mac 소스 대응: Sources/XFinder/Views/DetailView.swift (+ FileDrag.swift, FolderDrop.swift) — 상세 목록 패널 (스펙 03) -->
    <UserControl.Resources>

        <!-- 목록 보기 행 (FileRowView) -->
        <DataTemplate x:Key="ListItemTemplate">
            <Border Height="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                    Background="{Binding RowBackground}"
                    Padding="10,0" SnapsToDevicePixels="True" AllowDrop="True"
                    MouseLeftButtonDown="Row_MouseLeftButtonDown"
                    MouseMove="Row_MouseMove"
                    MouseLeftButtonUp="Row_MouseLeftButtonUp"
                    MouseRightButtonUp="Row_MouseRightButtonUp"
                    LostMouseCapture="Row_LostMouseCapture"
                    DragOver="Row_DragOver" Drop="Row_Drop">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Left"
                          Width="{Binding IconColWidth, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}">
                        <Image Source="{Binding Icon}"
                               Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                    <TextBlock DockPanel.Dock="Right" Margin="6,0,0,0" VerticalAlignment="Center"
                               Width="{Binding KindColWidth, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               FontSize="{Binding MetaFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Text="{Binding KindText}" Foreground="{Binding MetaBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock DockPanel.Dock="Right" Margin="6,0,0,0" VerticalAlignment="Center"
                               Width="{Binding CreatedColWidth, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               FontSize="{Binding MetaFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Text="{Binding CreatedText}" Foreground="{Binding MetaBrush}"
                               ToolTip="{Binding CreatedTip}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock DockPanel.Dock="Right" Margin="6,0,0,0" VerticalAlignment="Center"
                               Width="{Binding ModifiedColWidth, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               FontSize="{Binding MetaFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Text="{Binding ModifiedText}" Foreground="{Binding MetaBrush}"
                               ToolTip="{Binding ModifiedTip}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock DockPanel.Dock="Right" Margin="6,0,0,0" VerticalAlignment="Center" TextAlignment="Right"
                               Width="{Binding SizeColWidth, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               FontSize="{Binding MetaFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Text="{Binding SizeText}" Foreground="{Binding NameBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <views:MiddleEllipsisTextBlock Margin="6,0,0,0" VerticalAlignment="Center"
                               FullText="{Binding NameText}"
                               FontSize="{Binding NameFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Foreground="{Binding NameBrush}"/>
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- 그룹 헤더 행 (다음으로 그룹화) -->
        <DataTemplate x:Key="GroupHeaderTemplate">
            <Border Height="{Binding RowHeight, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                    Padding="10,0" SnapsToDevicePixels="True">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding HeaderTitle}" FontWeight="SemiBold"
                               FontSize="{Binding HeaderFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HeaderCountText}" Margin="6,0,0,0"
                               FontSize="{Binding GroupCountFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 아이콘 보기 셀 (IconCellView) -->
        <DataTemplate x:Key="IconCellTemplate">
            <Border Width="{Binding CellSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                    Height="{Binding CellSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                    Margin="4" Background="Transparent" AllowDrop="True"
                    Loaded="IconCell_Loaded"
                    MouseLeftButtonDown="Row_MouseLeftButtonDown"
                    MouseMove="Row_MouseMove"
                    MouseLeftButtonUp="Row_MouseLeftButtonUp"
                    MouseRightButtonUp="Row_MouseRightButtonUp"
                    LostMouseCapture="Row_LostMouseCapture"
                    DragOver="Row_DragOver" Drop="Row_Drop">
                <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">
                    <Image Source="{Binding Thumb}"
                           Width="{Binding ThumbSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                           Height="{Binding ThumbSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Border Background="{Binding LabelBackground}" CornerRadius="4" Padding="4,1" Margin="0,4,0,0"
                            HorizontalAlignment="Center">
                        <TextBlock Text="{Binding NameText}" Foreground="{Binding NameBrush}"
                                   FontSize="{Binding IconNameFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                                   MaxHeight="{Binding IconLabelMaxHeight, RelativeSource={RelativeSource AncestorType={x:Type views:DetailView}}}"
                                   TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <views:DetailRowTemplateSelector x:Key="ListRowSelector"
                                         RowTemplate="{StaticResource ListItemTemplate}"
                                         HeaderTemplate="{StaticResource GroupHeaderTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 열 헤더 -->
            <RowDefinition Height="Auto"/>   <!-- 구분선 -->
            <RowDefinition Height="*"/>      <!-- 목록/아이콘 그리드 -->
            <RowDefinition Height="Auto"/>   <!-- 구분선 -->
            <RowDefinition Height="22"/>     <!-- 상태 표시줄 -->
        </Grid.RowDefinitions>

        <!-- 열 헤더 (코드에서 구성) -->
        <Border Grid.Row="0" x:Name="HeaderBar"
                Background="{DynamicResource WindowBackgroundBrush}" Padding="10,4"/>
        <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource DividerBrush}"/>

        <!-- 목록 영역 (빈 영역 클릭/러버밴드/배경 메뉴/폴더 드롭) -->
        <Grid Grid.Row="2" x:Name="ContentRoot" Background="{DynamicResource TextBackgroundBrush}" AllowDrop="True"
              MouseLeftButtonDown="Background_MouseLeftButtonDown"
              MouseMove="Background_MouseMove"
              MouseLeftButtonUp="Background_MouseLeftButtonUp"
              LostMouseCapture="Background_LostMouseCapture"
              MouseRightButtonUp="Background_MouseRightButtonUp"
              DragOver="Background_DragOver" Drop="Background_Drop">

            <!-- 목록 보기 (가상화) -->
            <ItemsControl x:Name="ListHost" Focusable="False"
                          ItemTemplateSelector="{StaticResource ListRowSelector}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer x:Name="PART_Scroll" Focusable="False" CanContentScroll="True"
                                      Background="Transparent"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      ScrollChanged="ListScroll_ScrollChanged">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
            </ItemsControl>

            <!-- 아이콘 보기 (WrapPanel 그리드) -->
            <ScrollViewer x:Name="IconScroll" Visibility="Collapsed" Focusable="False"
                          Background="Transparent"
                          HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ListScroll_ScrollChanged">
                <ItemsControl x:Name="IconHost" Focusable="False" Margin="12"
                              ItemTemplate="{StaticResource IconCellTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- 빈/오류 상태 -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed" IsHitTestVisible="False"
                        VerticalAlignment="Center" HorizontalAlignment="Center" MinHeight="140">
                <TextBlock x:Name="EmptyIcon" FontFamily="{StaticResource IconFontFamily}" FontSize="26"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyText" FontSize="12" Margin="0,8,0,0" MaxWidth="420"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="3" Height="1" Fill="{DynamicResource DividerBrush}"/>

        <!-- 상태 표시줄 -->
        <Border Grid.Row="4" Background="{DynamicResource WindowBackgroundBrush}">
            <DockPanel Margin="10,0" LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" x:Name="StatusLeft" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" x:Name="StatusRight" FontSize="11" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusCenter" FontSize="11" Margin="8,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
