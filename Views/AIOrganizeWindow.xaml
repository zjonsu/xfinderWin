<!-- mac 소스 대응: Sources/XFinder/Views/AIOrganizeSheet.swift (AI 파일 정리 시트 — 5단계 상태 머신 + 안내 팝오버) -->
<Window x:Class="XFinder.Views.AIOrganizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 파일 정리" Width="480" Height="600"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="OnWindowKeyDown">
    <Window.Resources>

        <!-- 멀티라인 프롬프트 입력 (에디터 패딩 8/6) -->
        <Style x:Key="MultilineBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="8,6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 강조(적용/정리 분석) 버튼 -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="{DynamicResource AccentBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 보조(취소/다시 입력) 버튼 -->
        <Style x:Key="SubtleButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="{DynamicResource ControlFillBrush}"
                                BorderBrush="{DynamicResource ControlStrokeBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource ControlFillHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 헤더 닫기 버튼 (흰색 85%, 패딩 10) -->
        <Style x:Key="HeaderCloseButton" TargetType="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
        <DockPanel LastChildFill="True">

            <!-- ── 헤더: 보라→파랑 대각선 그라데이션, 높이 74 ── -->
            <Border DockPanel.Dock="Top" Height="74" MouseLeftButtonDown="OnHeaderDrag">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF7D4FF5" Offset="0"/>
                        <GradientStop Color="#FF368CFC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderIcon" FontFamily="{StaticResource IconFontFamily}"
                               FontSize="22" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="AI 파일 정리" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="HeaderSubtitle" FontSize="11" Foreground="#D9FFFFFF"
                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button x:Name="BtnClose" Grid.Column="2" Style="{StaticResource HeaderCloseButton}"
                            VerticalAlignment="Top" Click="OnClose" ToolTip="닫기 (Esc)">
                        <TextBlock x:Name="CloseIcon" FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="17" Foreground="#D9FFFFFF"/>
                    </Button>
                </Grid>
            </Border>
            <Rectangle DockPanel.Dock="Top" Height="1" Fill="{DynamicResource DividerBrush}"/>

            <!-- ── 본문: phase별 뷰 ── -->
            <Grid>

                <!-- input -->
                <Grid x:Name="InputPanel" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="어떻게 정리할까요? 자연어로 알려 주세요." FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                    <Border x:Name="InputBorder" Grid.Row="1" Height="96" CornerRadius="10"
                            BorderThickness="1" Margin="0,0,0,14">
                        <Grid>
                            <TextBox x:Name="InputBox" Style="{StaticResource MultilineBox}"
                                     TextChanged="OnInputChanged"/>
                            <TextBlock x:Name="Placeholder" Text="예: 확장자별로 폴더를 만들어 정리해줘"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="12,11,12,0" VerticalAlignment="Top" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Text="빠른 예시" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel x:Name="ChipsHost" Grid.Row="3"/>

                    <!-- 하단 행: 개인정보 라벨 + 정리 분석 -->
                    <Grid Grid.Row="5" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="PrivacyIcon" FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="PrivacyText" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" MaxWidth="290" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="BtnAnalyze" Grid.Column="1" Style="{StaticResource AccentButton}"
                                Content="정리 분석" IsEnabled="False" Click="OnAnalyze" VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Grid.Row="6" Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,14,0,14"/>

                    <!-- 안내 링크 2줄 -->
                    <StackPanel Grid.Row="7">
                        <Border x:Name="LocalGuideLink" CornerRadius="8" Padding="12,9" Cursor="Hand"
                                Margin="0,0,0,6" MouseLeftButtonDown="OnLocalGuide">
                            <DockPanel LastChildFill="True">
                                <TextBlock x:Name="LocalGuideIcon" DockPanel.Dock="Left"
                                           FontFamily="{StaticResource IconFontFamily}" FontSize="11"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock x:Name="LocalGuideChevron" DockPanel.Dock="Right"
                                           FontFamily="{StaticResource IconFontFamily}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="로컬 AI 설정 방법 — Ollama 설치 안내" FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <Border x:Name="GeminiGuideLink" CornerRadius="8" Padding="12,9" Cursor="Hand"
                                MouseLeftButtonDown="OnGeminiGuide">
                            <DockPanel LastChildFill="True">
                                <TextBlock x:Name="GeminiGuideIcon" DockPanel.Dock="Left"
                                           FontFamily="{StaticResource IconFontFamily}" FontSize="11"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock x:Name="GeminiGuideChevron" DockPanel.Dock="Right"
                                           FontFamily="{StaticResource IconFontFamily}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Gemini 설정 방법 — API 키 발급 안내" FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- loading -->
                <StackPanel x:Name="LoadingPanel" Margin="24" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="5" Margin="0,0,0,14"/>
                    <TextBlock Text="AI가 파일을 분석하고 있습니다…" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="로컬 모델이라 수십 초 걸릴 수 있어요." FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- preview -->
                <Grid x:Name="PreviewPanel" Margin="18" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CheckIcon" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="#FF28CD41" VerticalAlignment="Top" Margin="0,2,7,0"/>
                        <TextBlock x:Name="PreviewSummary" Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock x:Name="PreviewLine" Grid.Row="1" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <Border x:Name="PreviewListBorder" Grid.Row="2" CornerRadius="10" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="OpsHost"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel x:Name="DeleteNote" Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0"
                                Visibility="Collapsed">
                        <TextBlock x:Name="DeleteNoteIcon" FontFamily="{StaticResource IconFontFamily}" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"
                                   Margin="0,1,5,0"/>
                        <TextBlock Text="삭제 항목은 영구 삭제가 아니라 휴지통으로 이동되며, 필요하면 복구할 수 있습니다."
                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" MaxWidth="400"/>
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource SubtleButton}" Content="다시 입력"
                                HorizontalAlignment="Left" Click="OnBackToInput"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource SubtleButton}" Content="취소" Click="OnClose"/>
                            <Button x:Name="BtnApply" Style="{StaticResource AccentButton}" Content="적용"
                                    Margin="8,0,0,0" Click="OnApply"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- empty -->
                <StackPanel x:Name="EmptyPanel" Margin="24" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="EmptyIcon" FontFamily="{StaticResource IconFontFamily}" FontSize="30"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="옮길 파일이 없다고 판단했어요." FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="EmptySummary" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <Button Style="{StaticResource AccentButton}" Content="다시 입력"
                            HorizontalAlignment="Center" Click="OnBackToInput"/>
                </StackPanel>

                <!-- error -->
                <StackPanel x:Name="ErrorPanel" Margin="24" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorIcon" FontFamily="{StaticResource IconFontFamily}" FontSize="28"
                               Foreground="#FFFF9500" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ErrorText" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <Button Style="{StaticResource AccentButton}" Content="다시 시도"
                            HorizontalAlignment="Center" Click="OnBackToInput"/>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
